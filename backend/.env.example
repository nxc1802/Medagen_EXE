# BACKEND CONFIG
NODE_ENV="development"
PORT=3000
HOST="0.0.0.0"

# LLM PROVIDER SELECTION: 'google' | 'openai' | 'openrouter' | 'ollama' | 'alibaba'
LLM_PROVIDER="google"

# GOOGLE AI STUDIO / GEMINI (Required if LLM_PROVIDER="google")
GOOGLE_API_KEY=""
GOOGLE_MODEL_NAME="gemini-2.5-flash"

# OPENAI (Required if LLM_PROVIDER="openai")
OPENAI_API_KEY=""
OPENAI_MODEL_NAME="gpt-4o"

# OPENROUTER (Required if LLM_PROVIDER="openrouter")
OPENROUTER_API_KEY=""
OPENROUTER_MODEL_NAME="anthropic/claude-3-haiku"

# ALIBABA DASHSCOPE (Required if LLM_PROVIDER="alibaba")
ALIBABA_API_KEY=""
ALIBABA_MODEL_NAME="qwen-max"

# OLLAMA LOCAL (Required if LLM_PROVIDER="ollama")
OLLAMA_MODEL_NAME="llama3"
OLLAMA_BASE_URL="http://localhost:11434/v1"

# SUPABASE CONFIG (Backend RAG & Sessions)
SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""

# GOOGLE MAPS API (Required for Hospital Finder Tool)
GOOGLE_MAPS_API_KEY=""

# CV MODEL WORKER ENDPOINT (e.g. http://localhost:8000 for local docker compose)
CV_ENDPOINT="http://localhost:8000"
# API Key for CV Worker authentication handshake
CV_API_KEY="your-cv-worker-secret-token"
